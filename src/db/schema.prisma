generator client {
 provider = "prisma-client-js"
}

datasource db {
 provider = "postgresql"
 url      = env("DATABASE_URL")
}

model User {
 id        String   @id @default(cuid())
 name      String?
 email     String   @unique
 password  String?
 provider  String?
 createdAt DateTime @default(now())
 sessions  Session[]
 messages  Message[]
}

model Session {
 id        String   @id @default(cuid())
 userId    String
 user      User     @relation(fields: [userId], references: [id])
 createdAt DateTime @default(now())
}

model Message {
 id        String   @id @default(cuid())
 userId    String
 content   String
 role      String
 createdAt DateTime @default(now())
 user      User     @relation(fields: [userId], references: [id])
}